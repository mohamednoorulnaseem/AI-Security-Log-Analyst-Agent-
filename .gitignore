# ============================================================
# LogSentinel AI — Git Ignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/

# --- Virtual Environment ---
venv/
.venv/
env/

# --- Environment Variables ---
.env

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Data & Logs (user-uploaded, generated) ---
data/logs/*.log
data/logs/*.txt
data/benchmark_results.json
data/benchmark_manifest.json

# --- ChromaDB local storage ---
chroma_data/

# --- PostgreSQL local data ---
pgdata/

# --- Docker ---
docker/pgdata/

# --- Test artifacts ---
.pytest_cache/
htmlcov/
.coverage

# --- Streamlit ---
.streamlit/secrets.toml

# --- Misc ---
*.bak
*.tmp
*.log
