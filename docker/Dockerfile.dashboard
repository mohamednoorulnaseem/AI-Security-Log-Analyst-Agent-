# ============================================================
# LogSentinel AI — Streamlit Dashboard Dockerfile
# ============================================================
# Streamlit runs as a separate service so the API and dashboard
# can scale independently. In production you'd put Streamlit
# behind an auth proxy (e.g., Cloudflare Access or nginx).

FROM python:3.12-slim

WORKDIR /app

# Only install what the dashboard needs — not the full requirements.txt
RUN pip install --no-cache-dir \
    streamlit==1.45.1 \
    requests==2.32.3 \
    python-dotenv==1.1.0 \
    plotly==6.1.2 \
    pandas==2.2.3

# Copy dashboard code
COPY dashboard/ ./dashboard/

EXPOSE 8501

# Streamlit config: disable CORS warning, set server port
CMD ["streamlit", "run", "dashboard/app.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true", \
     "--browser.gatherUsageStats=false"]
